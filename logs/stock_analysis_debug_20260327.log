相较于2024年的39%、69%、81%、92%,TOP10房企销售金额集中度有所', 'siteName': '腾讯网', 'siteIcon': 'https://th.bochaai.com/favicon?domain_url=https://news.qq.com/rain/a/20260320A02ME700', 'datePublished': '2026-03-20T07:32:49+08:00', 'dateLastCrawled': '2026-03-20T07:32:49Z', 'cachedPageUrl': None, 'language': None, 'isFamilyFriendly': None, 'isNavigational': None}], 'someResultsRemoved': True}, 'images': None, 'videos': None}}
